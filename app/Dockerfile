# Базовый образ: минимальный Python 3.11 на Alpine (размер ~50 МБ)
FROM python:3.11-alpine
# Рабочая директория внутри контейнера
WORKDIR /app
# Копируем скрипт приложения в контейнер
COPY app.py .
# Документируем порт, который будет слушать приложение (не пробрасывает автоматически!)
EXPOSE 8080
# Команда по умолчанию при запуске контейнера
CMD ["python", "app.py"]
